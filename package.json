{
  "name": "@go-mondo/aws-lambda-nodejs-authorizer",
  "version": "0.1.0",
  "description": "AWS Lambda Node.js authorizers for Mondo Identity.",
  "type": "module",
  "sideEffects": false,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=24"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cdk-rest-api": {
      "types": "./dist/cdk-rest-api/construct.d.ts",
      "import": "./dist/cdk-rest-api/construct.js"
    },
    "./cdk-rest-api/handler": {
      "types": "./dist/cdk-rest-api/handler.d.ts",
      "import": "./dist/cdk-rest-api/handler.js"
    }
  },
  "files": [
    "dist",
    "src/cdk-rest-api/handler.ts"
  ],
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.json",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "format": "biome check --write .",
    "lint": "biome check .",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm check && pnpm build",
    "prepare": "husky",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.33.0",
    "jose": "^6.1.0"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.253.0",
    "constructs": "^10.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.7",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@types/aws-lambda": "^8.10.158",
    "@types/node": "^24.10.1",
    "aws-cdk-lib": "^2.253.0",
    "constructs": "^10.4.2",
    "esbuild": "^0.27.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,jsonc,md}": "biome check --write --no-errors-on-unmatched"
  }
}
